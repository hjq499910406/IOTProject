{
  "name": "t-web-dev",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm run vite:dev",
    "vite:dev": "pnpm install && vite",
    "prebuild:page": "echo need to set: nvm use 18.18.0",
    "build": "node ./scripts/buildAllPages.mjs",
    "build:pages": "node ./scripts/buildPage.mjs",
    "build:portals": "node ./scripts/buildAllPortals.mjs",
    "build:portal": "node ./scripts/buildPortal.mjs",
    "build:ucs": "node ./scripts/buildAllUCs.mjs",
    "build:uc": "node ./scripts/buildUC.mjs",
    "preview": "vite preview",
    "test": "vitest run --coverage",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@teld/q-components": "^0.1.8",
    "@teld/t-components": "^0.1.1",
    "@vitest/coverage-v8": "^1.0.1",
    "hls.js": "^1.6.16",
    "vue": "^3.3.4",
    "vue-router": "^4.2.4"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.3.3",
    "@teld/types": "^0.0.2",
    "@tsconfig/node18": "^18.2.2",
    "@types/jsdom": "^21.1.3",
    "@types/node": "^18.17.17",
    "@vitejs/plugin-legacy": "^4.1.1",
    "@vitejs/plugin-vue": "^4.3.4",
    "@vitejs/plugin-vue-jsx": "^3.0.2",
    "@vitest/coverage-v8": "^1.0.1",
    "@vue/eslint-config-prettier": "^8.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/test-utils": "^2.4.1",
    "@vue/tsconfig": "^0.4.0",
    "cac": "^6.7.14",
    "ejs": "^3.1.9",
    "eslint": "^8.49.0",
    "eslint-plugin-vue": "^9.17.0",
    "glob": "^10.3.10",
    "jsdom": "^22.1.0",
    "npm-run-all2": "^6.0.6",
    "prettier": "^3.0.3",
    "terser": "^5.22.0",
    "typescript": "~5.2.0",
    "vite": "^4.4.9",
    "vite-plugin-html": "^3.2.0",
    "vitest": "^1.0.1",
    "vue-i18n": "9",
    "vue-tsc": "^1.8.19"
  }
}
